# Multi-stage build for craft-agents-server
# Stage 1: Build the server distribution using bun
# Stage 2: Slim runtime image

FROM oven/bun:1.3 AS builder

RUN apt-get update && apt-get install -y curl unzip && rm -rf /var/lib/apt/lists/*

# Download kubernetes-mcp-server native binary
RUN curl -fsSL "https://github.com/containers/kubernetes-mcp-server/releases/latest/download/kubernetes-mcp-server-linux-amd64" \
    -o /usr/local/bin/kubernetes-mcp-server && chmod +x /usr/local/bin/kubernetes-mcp-server

# Download neo4j-mcp binary
RUN curl -fsSL "https://github.com/neo4j/mcp/releases/latest/download/neo4j-mcp_Linux_x86_64.tar.gz" \
    -o /tmp/neo4j-mcp.tar.gz && tar -xzf /tmp/neo4j-mcp.tar.gz -C /usr/local/bin/ && \
    chmod +x /usr/local/bin/neo4j-mcp && rm /tmp/neo4j-mcp.tar.gz

# Download portainer-mcp binary (distributed as tarball)
RUN PORTAINER_MCP_VERSION="v0.7.0" && \
    curl -fsSL "https://github.com/portainer/portainer-mcp/releases/download/${PORTAINER_MCP_VERSION}/portainer-mcp-${PORTAINER_MCP_VERSION}-linux-amd64.tar.gz" \
    -o /tmp/portainer-mcp.tar.gz && \
    tar -xzf /tmp/portainer-mcp.tar.gz -C /tmp && \
    find /tmp -maxdepth 2 -name "portainer-mcp" -type f -exec mv {} /usr/local/bin/portainer-mcp \; && \
    chmod +x /usr/local/bin/portainer-mcp && \
    rm /tmp/portainer-mcp.tar.gz

# Download kubectl
RUN KUBECTL_VERSION=$(curl -fsSL https://dl.k8s.io/release/stable.txt) && \
    curl -fsSL "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl" \
    -o /usr/local/bin/kubectl && chmod +x /usr/local/bin/kubectl

# Download helm3
RUN HELM_VERSION=$(curl -fsSL --retry 5 --retry-all-errors --retry-delay 5 https://api.github.com/repos/helm/helm/releases/latest | grep '"tag_name"' | head -1 | sed 's/.*"v\([^"]*\)".*/\1/') && \
    curl -fsSL --retry 5 --retry-all-errors --retry-delay 5 --connect-timeout 20 --max-time 300 \
    "https://get.helm.sh/helm-v${HELM_VERSION}-linux-amd64.tar.gz" \
    -o /tmp/helm.tar.gz && tar -xzf /tmp/helm.tar.gz -C /tmp && \
    mv /tmp/linux-amd64/helm /usr/local/bin/helm && \
    chmod +x /usr/local/bin/helm && rm -rf /tmp/helm.tar.gz /tmp/linux-amd64

# Download OpenTofu CLI — pinned to match storeminder/.tool-versions (opentofu 1.9.x).
# Ships a standalone zip per release containing the `tofu` binary.
RUN TOFU_VERSION=1.9.4 && \
    curl -fsSL "https://github.com/opentofu/opentofu/releases/download/v${TOFU_VERSION}/tofu_${TOFU_VERSION}_linux_amd64.zip" \
    -o /tmp/tofu.zip && unzip -o /tmp/tofu.zip tofu -d /tmp && \
    mv /tmp/tofu /usr/local/bin/tofu && \
    chmod +x /usr/local/bin/tofu && rm -f /tmp/tofu.zip

# Download Terragrunt CLI — the apply wrapper used to drive the storeminder
# OpenTofu stack (terragrunt run-all plan/apply). Pinned to match
# storeminder/.tool-versions (terragrunt 0.69.13). Ships as a standalone binary.
RUN TERRAGRUNT_VERSION=0.69.13 && \
    curl -fsSL "https://github.com/gruntwork-io/terragrunt/releases/download/v${TERRAGRUNT_VERSION}/terragrunt_linux_amd64" \
    -o /usr/local/bin/terragrunt && chmod +x /usr/local/bin/terragrunt

# Download gh (GitHub CLI)
RUN GH_VERSION=$(curl -fsSL https://api.github.com/repos/cli/cli/releases/latest | grep '"tag_name"' | head -1 | sed 's/.*"v\([^"]*\)".*/\1/') && \
    curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_amd64.tar.gz" \
    -o /tmp/gh.tar.gz && tar -xzf /tmp/gh.tar.gz -C /tmp && \
    mv /tmp/gh_${GH_VERSION}_linux_amd64/bin/gh /usr/local/bin/gh && \
    chmod +x /usr/local/bin/gh && rm -rf /tmp/gh.tar.gz /tmp/gh_*

# Download Docker CLI (static binary) — talks to the host's Docker daemon via DOCKER_HOST
RUN DOCKER_VERSION=28.3.3 && \
    curl -fsSL "https://download.docker.com/linux/static/stable/x86_64/docker-${DOCKER_VERSION}.tgz" \
    -o /tmp/docker.tgz && tar -xzf /tmp/docker.tgz -C /tmp && \
    mv /tmp/docker/docker /usr/local/bin/docker && \
    chmod +x /usr/local/bin/docker && rm -rf /tmp/docker /tmp/docker.tgz

# Download Docker Compose v2 as a CLI plugin (system-wide install path)
RUN COMPOSE_VERSION=v2.35.1 && \
    mkdir -p /usr/libexec/docker/cli-plugins && \
    curl -fsSL "https://github.com/docker/compose/releases/download/${COMPOSE_VERSION}/docker-compose-linux-x86_64" \
    -o /usr/libexec/docker/cli-plugins/docker-compose && \
    chmod +x /usr/libexec/docker/cli-plugins/docker-compose

# Download Telepresence OSS CLI — used to bridge the agent (or its docker containers) into a Kubernetes cluster's network
RUN TELEPRESENCE_VERSION=v2.22.0 && \
    curl -fsSL "https://app.getambassador.io/download/tel2oss/releases/download/${TELEPRESENCE_VERSION}/telepresence-linux-amd64" \
    -o /usr/local/bin/telepresence && chmod +x /usr/local/bin/telepresence

# Download rd (Rundeck CLI) jar
RUN RD_VERSION=$(curl -fsSL --retry 5 --retry-all-errors --retry-delay 5 https://api.github.com/repos/rundeck/rundeck-cli/releases/latest | grep '"tag_name"' | head -1 | sed 's/.*"v\([^"]*\)".*/\1/') && \
    curl -fsSL --retry 5 --retry-all-errors --retry-delay 5 --connect-timeout 20 --max-time 300 \
    "https://github.com/rundeck/rundeck-cli/releases/download/v${RD_VERSION}/rundeck-cli-${RD_VERSION}-all.jar" \
    -o /usr/local/lib/rd.jar

# Build tekton-mcp-server from source (no pre-built releases available)
RUN curl -fsSL https://go.dev/dl/go1.24.2.linux-amd64.tar.gz | tar -C /usr/local -xzf - && \
    GOBIN=/usr/local/bin /usr/local/go/bin/go install github.com/tektoncd/mcp-server/cmd/tekton-mcp-server@main && \
    rm -rf /usr/local/go

# Install argocd-mcp as a standalone package
RUN mkdir -p /opt/argocd-mcp && cd /opt/argocd-mcp && \
    bun init -y && bun add --backend=copyfile argocd-mcp@0.5.0

# Install sonatype-mcp (Sonatype Nexus Repository Manager MCP)
RUN mkdir -p /opt/sonatype-mcp && cd /opt/sonatype-mcp && \
    bun init -y && bun add --backend=copyfile @brianveltman/sonatype-mcp

# Install aws-s3-mcp (S3 / S3-compatible storage MCP)
RUN mkdir -p /opt/aws-s3-mcp && cd /opt/aws-s3-mcp && \
    bun init -y && bun add --backend=copyfile aws-s3-mcp

# Install authentik-mcp (Authentik IAM MCP)
RUN mkdir -p /opt/authentik-mcp && cd /opt/authentik-mcp && \
    bun init -y && bun add --backend=copyfile @cdmx/authentik-mcp

# Install gcloud-mcp (official Google Cloud gcloud MCP server)
RUN mkdir -p /opt/gcloud-mcp && cd /opt/gcloud-mcp && \
    bun init -y && bun add --backend=copyfile @google-cloud/gcloud-mcp

WORKDIR /src
COPY . .

RUN bun install --backend=copyfile --frozen-lockfile 2>/dev/null || bun install --backend=copyfile
RUN bun run server:build:subprocess
RUN bun run server:build:linux-x64
RUN mkdir -p /src/dist/server/resources/pi-agent-server && \
    cp /src/packages/pi-agent-server/dist/index.js /src/dist/server/resources/pi-agent-server/

# Build the open-source session viewer (apps/viewer -> apps/viewer/dist).
# The in-process share server (started when CRAFT_SHARE_PORT is set) serves this
# SPA under /s and aborts at startup if the built viewer is missing. vite base
# is /s/ (see apps/viewer/vite.config.ts); output dir is apps/viewer/dist.
RUN bun run --cwd apps/viewer build

# Build the browser web UI (apps/webui -> apps/webui/dist). The server enables
# the web UI on the RPC port only when CRAFT_WEBUI_DIR exists (existsSync gate);
# without it, the root path serves bare RPC (HTTP 426). vite base is ./; output
# dir is apps/webui/dist.
RUN bun run --cwd apps/webui build

# ---

FROM oven/bun:1.3-slim

WORKDIR /app

# ---------------------------------------------------------------------------
# Environment / toolchain layers.
#
# These RUNs are independent of the built server dist, so they are placed
# BEFORE the `COPY --from=builder` lines below. A source-only commit changes
# only the dist (and the two context COPYs at the very end), so keeping the
# heavyweight apt/pip/sbt/AWS CLI/gcloud SDK installs ahead of the dist COPY
# lets them cache-hit on every source-only rebuild instead of re-downloading
# ~1GB+ of packages. Do not move dist-dependent steps up here — see the block
# after the COPYs. (storeminder-ai/craft-agents#62)
# ---------------------------------------------------------------------------

RUN apt-get update && apt-get install -y \
      git curl gnupg default-jdk-headless gosu rsync sudo iptables \
      python3 python3-pip python3-venv python3-dev \
      python3-yaml python3-requests \
      jq ripgrep tree file less unzip vim-tiny ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Make pip behave like pip on a dev box. The container is a single-tenant
# agent sandbox (cf. passwordless sudo below), so PEP 668's
# externally-managed guard is friction without a security benefit. Removing
# it lets the agent `pip install <foo>` without --break-system-packages.
RUN rm -f /usr/lib/python3*/EXTERNALLY-MANAGED && \
    python3 -m pip install \
      pyyaml requests httpx rich typer click \
      python-dateutil tabulate

ARG CRAFT_UID=1007
ARG CRAFT_GID=1007
RUN groupadd -g ${CRAFT_GID} craftagents && \
    useradd -u ${CRAFT_UID} -g ${CRAFT_GID} -m -d /home/craftagents -s /bin/sh craftagents && \
    mkdir -p /home/craftagents/.craft-agent /home/craftagents/.ssh /home/craftagents/.kube && \
    chown -R craftagents:craftagents /home/craftagents

# Passwordless sudo for craftagents. The container is a single-tenant agent
# sandbox; tools like telepresence gate on euid==0 even when the relevant
# capabilities (e.g. NET_ADMIN granted via compose cap_add) are already
# present, so giving the agent a frictionless escalation path is the simplest
# fix and matches the trust model of the container as a whole.
RUN echo 'craftagents ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/craftagents && \
    chmod 440 /etc/sudoers.d/craftagents

# Create rd (Rundeck CLI) wrapper script
RUN printf '#!/bin/sh\nexec java -jar /usr/local/lib/rd.jar "$@"\n' > /usr/local/bin/rd && \
    chmod +x /usr/local/bin/rd

# Install sbt. apt-key is not available in current Debian slim images, so
# install the Scala SBT key into a keyring and reference it with signed-by.
RUN curl -fsSL --retry 5 --retry-all-errors --retry-delay 5 \
    "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x2EE0EA64E40A89B84B2DF73499E82A75642AC823" \
    | gpg --dearmor -o /usr/share/keyrings/sbt-archive-keyring.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/sbt-archive-keyring.gpg] https://repo.scala-sbt.org/scalasbt/debian all main" \
    > /etc/apt/sources.list.d/sbt.list && \
    apt-get update && apt-get install -y sbt && rm -rf /var/lib/apt/lists/*

# Install AWS CLI v2 (required for SSO device-auth login and profile management)
RUN ARCH=$(dpkg --print-architecture) && \
    case "$ARCH" in \
      amd64) AWS_ARCH=x86_64 ;; \
      arm64) AWS_ARCH=aarch64 ;; \
      *) echo "unsupported arch: $ARCH"; exit 1 ;; \
    esac && \
    apt-get update && apt-get install -y unzip less && \
    curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-${AWS_ARCH}.zip" -o /tmp/awscliv2.zip && \
    unzip -q /tmp/awscliv2.zip -d /tmp && \
    /tmp/aws/install --bin-dir /usr/local/bin --install-dir /usr/local/aws-cli && \
    rm -rf /tmp/aws /tmp/awscliv2.zip && \
    apt-get purge -y unzip && apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

# Wrapper for awslabs.aws-api-mcp-server.  The container exports global
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_ENDPOINT_URL env vars for the
# legacy s3proxy "storage" source; if those leak into this MCP subprocess,
# boto3's env-var credential provider wins over the AWS_PROFILE shared-config
# lookup and the server silently uses the wrong account.  Strip them before
# exec so AWS_PROFILE is the authoritative selector.
RUN printf '%s\n' \
    '#!/bin/sh' \
    'unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN AWS_ENDPOINT_URL AWS_S3_FORCE_PATH_STYLE' \
    'exec awslabs.aws-api-mcp-server "$@"' \
    > /usr/local/bin/aws-api-mcp && \
    chmod +x /usr/local/bin/aws-api-mcp

# Install Google Cloud SDK (gcloud CLI).  Required by @google-cloud/gcloud-mcp
# for command execution and for `gcloud auth login` / `gcloud config
# configurations` profile management.  Uses the upstream apt repo with a
# signed-by keyring (apt-key is unavailable on slim images).
RUN curl -fsSL "https://packages.cloud.google.com/apt/doc/apt-key.gpg" \
    | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" \
    > /etc/apt/sources.list.d/google-cloud-sdk.list && \
    apt-get update && apt-get install -y google-cloud-cli && \
    rm -rf /var/lib/apt/lists/*

# Wrapper for @google-cloud/gcloud-mcp.  Strips raw GCP credential env vars
# that would override the active gcloud configuration as the authoritative
# account selector.  Mirrors the aws-api-mcp wrapper's defense-in-depth role.
# Leaves configuration-selector vars (CLOUDSDK_ACTIVE_CONFIG_NAME,
# CLOUDSDK_AUTH_IMPERSONATE_SERVICE_ACCOUNT, CLOUDSDK_CORE_PROJECT) untouched
# so per-source env blocks can set them.
RUN printf '%s\n' \
    '#!/bin/sh' \
    'unset GOOGLE_APPLICATION_CREDENTIALS GOOGLE_OAUTH_ACCESS_TOKEN CLOUDSDK_AUTH_ACCESS_TOKEN' \
    'exec node /opt/gcloud-mcp/node_modules/@google-cloud/gcloud-mcp/dist/bundle.js "$@"' \
    > /usr/local/bin/gcloud-mcp && \
    chmod +x /usr/local/bin/gcloud-mcp

# craft-bg: run a command DETACHED from the per-turn Claude Agent SDK subprocess
# so it survives turn boundaries.  The server runs each turn as a fresh, ephemeral
# SDK subprocess; a `run_in_background` Bash task is its child and is killed when
# the turn ends.  `setsid` reparents the work to PID 1 (the long-lived server), so
# it keeps running across turns.  Output + status land under the session dir.
# See skills/_background-tasks-rules.md and electinfo/craft-agents#26.
RUN printf '%s\n' \
    '#!/bin/sh' \
    'set -eu' \
    'BG="${CRAFT_SESSION_DIR:-$HOME/.craft-bg}/bg"; mkdir -p "$BG"' \
    'cmd="${1:-}"; [ "$#" -gt 0 ] && shift' \
    'case "$cmd" in' \
    '  start)' \
    '    spec="${1:-}"; [ "$#" -gt 0 ] && shift; name="bg-$$"' \
    '    [ "${1:-}" = "--name" ] && name="${2:-$name}"' \
    '    [ -n "$spec" ] || { echo "usage: craft-bg start <cmd> [--name N]" >&2; exit 2; }' \
    '    setsid nohup sh -c "( $spec ); ec=\$?; echo \$ec > \"$BG/$name.code\"; touch \"$BG/$name.done\"" \' \
    '      > "$BG/$name.log" 2>&1 & echo "$!" > "$BG/$name.pid"' \
    '    echo "started $name (pid $(cat "$BG/$name.pid")) -> $BG/$name.log" ;;' \
    '  status)' \
    '    n="${1:?usage: craft-bg status <name>}"' \
    '    if [ -f "$BG/$n.done" ]; then echo "done (exit $(cat "$BG/$n.code" 2>/dev/null || echo ?))";' \
    '    elif kill -0 "$(cat "$BG/$n.pid" 2>/dev/null || echo -1)" 2>/dev/null; then echo running;' \
    '    else echo unknown; fi ;;' \
    '  log)  tail -n "${2:-40}" "$BG/${1:?usage: craft-bg log <name> [lines]}.log" ;;' \
    '  list) ls -1 "$BG"/*.pid 2>/dev/null | sed "s#.*/##; s/\.pid\$//" || true ;;' \
    '  *) echo "usage: craft-bg {start <cmd> [--name N] | status <name> | log <name> [lines] | list}" >&2; exit 2 ;;' \
    'esac' \
    > /usr/local/bin/craft-bg && \
    chmod +x /usr/local/bin/craft-bg

# ---------------------------------------------------------------------------
# COPY from the builder stage.
#
# The dist COPYs below (server / viewer / webui) change on every source commit
# and therefore invalidate everything AFTER this point. Keep only genuinely
# dist-dependent steps below them. The remaining COPYs are prebuilt tool
# binaries pulled from the builder's early (source-independent) layers.
# ---------------------------------------------------------------------------

COPY --from=builder /src/dist/server/ .
# Ship the built session viewer so the share server finds it at its default
# location: CRAFT_BUNDLED_ASSETS_ROOT/apps/viewer/dist == /app/apps/viewer/dist.
COPY --from=builder /src/apps/viewer/dist /app/apps/viewer/dist
# Ship the built web UI so the server enables it at CRAFT_WEBUI_DIR
# (/app/apps/webui/dist) and serves it on the RPC port for browser clients.
COPY --from=builder /src/apps/webui/dist /app/apps/webui/dist
COPY --from=builder /usr/local/bin/kubectl /usr/local/bin/kubectl
COPY --from=builder /usr/local/bin/helm /usr/local/bin/helm
COPY --from=builder /usr/local/bin/tofu /usr/local/bin/tofu
COPY --from=builder /usr/local/bin/terragrunt /usr/local/bin/terragrunt
COPY --from=builder /usr/local/bin/kubernetes-mcp-server /usr/local/bin/kubernetes-mcp-server
COPY --from=builder /usr/local/bin/tekton-mcp-server /usr/local/bin/tekton-mcp-server
COPY --from=builder /usr/local/bin/neo4j-mcp /usr/local/bin/neo4j-mcp
COPY --from=builder /usr/local/bin/portainer-mcp /usr/local/bin/portainer-mcp
COPY --from=builder /opt/argocd-mcp /opt/argocd-mcp
COPY --from=builder /opt/sonatype-mcp /opt/sonatype-mcp
COPY --from=builder /opt/aws-s3-mcp /opt/aws-s3-mcp
COPY --from=builder /opt/authentik-mcp /opt/authentik-mcp
COPY --from=builder /opt/gcloud-mcp /opt/gcloud-mcp
COPY --from=builder /usr/local/bin/gh /usr/local/bin/gh
COPY --from=builder /usr/local/bin/docker /usr/local/bin/docker
COPY --from=builder /usr/libexec/docker/cli-plugins/docker-compose /usr/libexec/docker/cli-plugins/docker-compose
COPY --from=builder /usr/local/bin/telepresence /usr/local/bin/telepresence
COPY --from=builder /usr/local/lib/rd.jar /usr/local/lib/rd.jar

# ---------------------------------------------------------------------------
# Dist-dependent steps — MUST stay after the dist COPY above.
#   * chmod operates on the copied bin/craft-server, vendor/bun/bun and
#     resources/bin/* (including resources/bin/uv).
#   * the uv tool installs invoke /app/resources/bin/uv, shipped in the dist.
#   * the trailing `bun install` resolves the copied dist's package.json.
# ---------------------------------------------------------------------------

RUN chmod +x bin/craft-server vendor/bun/bun resources/bin/uv && \
    for f in resources/bin/*; do [ -f "$f" ] && chmod +x "$f"; done

RUN bun install --backend=copyfile --frozen-lockfile 2>/dev/null || bun install --backend=copyfile

ENV CRAFT_IS_PACKAGED=true
ENV CRAFT_BUNDLED_ASSETS_ROOT=/app
ENV CRAFT_APP_ROOT=/app
ENV CRAFT_RESOURCES_PATH=/app/resources
ENV CRAFT_UV=/app/resources/bin/uv
ENV CRAFT_SCRIPTS=/app/resources/scripts
ENV CRAFT_RPC_HOST=0.0.0.0
ENV CRAFT_RPC_PORT=9100
ENV PATH="/app/resources/bin:/app/vendor/bun:${PATH}"

# Host Docker access — assumes the host exposes dockerd on tcp://172.17.0.1:2376
# (the default Docker bridge gateway). Override at run time via -e DOCKER_HOST=...
# if the host listens elsewhere. Plain HTTP, no TLS — only safe behind a trusted
# bridge network.
ENV DOCKER_HOST=tcp://172.17.0.1:2376

# Install rundeck-mcp server (Python MCP for Rundeck automation)
# Uses uv tool install with explicit dirs so binaries are accessible to non-root user.
# Depends on /app/resources/bin/uv (from the dist COPY), so it stays after the COPYs.
ENV UV_TOOL_DIR=/opt/uv-tools
ENV UV_TOOL_BIN_DIR=/usr/local/bin
ENV UV_PYTHON_INSTALL_DIR=/opt/uv-python
RUN /app/resources/bin/uv tool install git+https://github.com/marcelobrake/rundeck-mcp.git && \
    apt-get update && apt-get install -y build-essential && \
    /app/resources/bin/uv tool install postgres-mcp --python 3.12 && \
    /app/resources/bin/uv tool install awslabs.aws-api-mcp-server --python 3.12 && \
    apt-get remove -y build-essential && apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/* && \
    chmod -R a+rX /opt/uv-tools /opt/uv-python

# GitHub App installation-token rotator (storeminder-ai/craft-agents#33). Runs as
# an init container (--oneshot) + a long-lived sidecar in 20-deployment.yaml so the
# agent authors git/gh as the storeminder-sidekick App instead of a human PAT.
COPY bin/craft-gh-rotator /usr/local/bin/craft-gh-rotator
RUN chmod +x /usr/local/bin/craft-gh-rotator

COPY docker-entrypoint.sh /usr/local/bin/craft-agent-entrypoint.sh
RUN chmod +x /usr/local/bin/craft-agent-entrypoint.sh

# oven/bun images default to the non-root bun user. The entrypoint must start
# as root so it can migrate ownership of bind-mounted Craft Agent state from
# the old uid/gid before dropping to craftagents with gosu.
USER root

EXPOSE 9100

ENTRYPOINT ["/usr/local/bin/craft-agent-entrypoint.sh"]
